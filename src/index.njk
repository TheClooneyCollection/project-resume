---
layout: layout-responsive.njk
permalink: index.html
---
{% from "components/index-items.njk" import contactItem, skillItem, experienceItem, projectItem, interestItem %}

{% set currentEnvironment = environment or 'development' %}

<section class="intro">
  <div class="intro__heading">
    <h1 class="intro__name">{{ cvData.name }}</h1>
    <ul class="contact-list">
      {{ contactItem(cvData.contact.website) }}
      {% if cvData.contact.githubProfile %}
      {{ contactItem(cvData.contact.githubProfile) }}
      {% endif %}
      {% if cvData.contact.githubCollection %}
      {{ contactItem(cvData.contact.githubCollection) }}
      {% endif %}
    </ul>
    <p class="intro__summary">{{ cvData.summary }}</p>
  </div>
</section>

{% if cvData.skills %}
<section class="section skills">
  <div class="section__heading">
    <h2>Core Skills</h2>
  </div>
  <div class="skills-grid">
    {% for skill in cvData.skills %}
    {{ skillItem(skill) }}
    {% endfor %}
  </div>
</section>
{% endif %}

{% if cvData.relevant %}
<section class="section experience">
  <div class="section__heading">
    <h2>Relevant Experience</h2>
  </div>
  <ol class="experience-list">
    {% set currentEnvironment = environment or 'development' %}
    {% set shouldFilter = currentEnvironment == 'development' %}
    {% set includedTags = (cvData.tags and cvData.tags.included) or [] %}
    {% set excludedTags = (cvData.tags and cvData.tags.excluded) or [] %}
    {% set includedSet = includedTags | toSet %}
    {% set excludedSet = excludedTags | toSet %}
    {% set includeAllTags = includedSet.has('all') %}
    {% for job in cvData.relevant %}
    {{ experienceItem(job, shouldFilter, excludedSet, includedSet, includeAllTags) }}
    {% endfor %}
  </ol>
</section>
{% endif %}

<section class="section experience">
  <div class="section__heading">
    <h2>Professional Experience</h2>
  </div>
  <ol class="experience-list">
    {% set currentEnvironment = environment or 'development' %}
    {% set shouldFilter = currentEnvironment == 'development' %}
    {% set includedTags = (cvData.tags and cvData.tags.included) or [] %}
    {% set excludedTags = (cvData.tags and cvData.tags.excluded) or [] %}
    {% set includedSet = includedTags | toSet %}
    {% set excludedSet = excludedTags | toSet %}
    {% set includeAllTags = includedSet.has('all') %}
    {% for job in cvData.experience %}
    {{ experienceItem(job, shouldFilter, excludedSet, includedSet, includeAllTags) }}
    {% endfor %}
  </ol>
</section>

{% if cvData.openSourceProjects %}
<section class="section projects">
  <div class="section__heading">
    <h2>Open Source Projects</h2>
  </div>
  <div class="card-grid">
    {% set currentEnvironment = environment or 'development' %}
    {% set shouldFilter = currentEnvironment == 'development' %}
    {% set includedTags = (cvData.tags and cvData.tags.included) or [] %}
    {% set excludedTags = (cvData.tags and cvData.tags.excluded) or [] %}
    {% set includedSet = includedTags | toSet %}
    {% set excludedSet = excludedTags | toSet %}
    {% set includeAllTags = includedSet.has('all') %}
    {% for project in cvData.openSourceProjects %}
    {{ projectItem(project, shouldFilter, excludedSet, includedSet, includeAllTags) }}
    {% endfor %}
  </div>
  {% if cvData.contact.projects %}
  <p><a href="{{ cvData.contact.projects }}" target="_blank" rel="noopener">View additional open source projects</a></p>
  {% endif %}
</section>
{% endif %}

{% if cvData.interests %}
<section class="section interests">
  <div class="section__heading">
    <h2>Interests</h2>
  </div>
  <ul class="chip-list">
    {% for interest in cvData.interests %}
    {{ interestItem(interest) }}
    {% endfor %}
  </ul>
</section>
{% endif %}
